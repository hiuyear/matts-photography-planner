PORT=3001
FATHOM_API_KEY=your_fathom_api_key

# Email delivery — preview needs no setup (default)
EMAIL_MODE=preview

# Optional: real send via personal Gmail (no DNS verification)
# EMAIL_MODE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=you@gmail.com

# Optional: Resend (requires verified domain DNS)
# EMAIL_MODE=resend
# RESEND_API_KEY=your_resend_api_key
# FROM_EMAIL=matt@nixhernandez.com
