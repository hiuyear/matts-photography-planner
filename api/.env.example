PORT=3001
FATHOM_API_KEY=your_fathom_api_key

# LLM extraction (uses lib/extraction/prompt.md)
# Option A (default): local Ollama — no keys needed if Ollama is running
# LLM_API_URL=http://localhost:11434/v1/chat/completions
# LLM_MODEL=llama3.1:8b
# LLM_NUM_CTX=4096

# Option B: OpenAI-compatible
# LLM_API_KEY=your_openai_or_compatible_key
# LLM_MODEL=gpt-4o-mini
# LLM_API_URL=https://api.openai.com/v1/chat/completions

# Option C: Lovable gateway
# LOVABLE_API_KEY=your_lovable_key

# Set EXTRACT_STUB=true to force mock extraction (demo without LLM)
# EXTRACT_STUB=true

# Email delivery — preview needs no setup (default)
EMAIL_MODE=preview

# Optional: real send via personal Gmail (no DNS verification)
# EMAIL_MODE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=you@gmail.com
