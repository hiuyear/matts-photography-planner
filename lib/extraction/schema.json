{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fieldinvoice.local/schemas/extract-result.schema.json",
  "title": "FieldInvoice Extract Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["client", "line_items", "tbd_items", "deposit_paid", "summary"],
  "properties": {
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "email"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "line_items": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "selected", "price", "quantity", "price_source", "source_quote"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["wedding_base", "elopement", "engagement", "second_shooter", "extra_hour", "travel"]
          },
          "label": { "type": "string" },
          "selected": { "type": "boolean" },
          "price": { "type": "number" },
          "quantity": { "type": "number" },
          "price_source": {
            "type": "string",
            "enum": ["default", "quoted"]
          },
          "source_quote": { "type": "string" }
        }
      }
    },
    "tbd_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "note", "source_quote"],
        "properties": {
          "label": { "type": "string" },
          "note": { "type": "string" },
          "source_quote": { "type": "string" }
        }
      }
    },
    "deposit_paid": {
      "type": ["boolean", "null"]
    },
    "summary": { "type": "string" }
  }
}
